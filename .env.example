# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=trainhub
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=trainhub

# Full connection URL used by the API server (auto-constructed from the above in
# docker-compose.yml; set this directly if you use an external database).
# DATABASE_URL=postgresql://trainhub:change_me@localhost:5432/trainhub

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# Secret used to sign session cookies — must be a long random string
SESSION_SECRET=replace-with-a-long-random-secret

# Directory where SCORM packages and PPTX uploads are stored
UPLOAD_DIR=/data/uploads

# ─── HTTP port exposed by the nginx frontend container ────────────────────────
HTTP_PORT=80

# ─── Production image pulls (docker-compose.prod.yml) ────────────────────────
# Your GitHub org/user + repo slug, e.g. acme/trainhub
GITHUB_REPOSITORY=your-org/trainhub
# Tag to pull (default: latest). Use a git SHA or semver tag for reproducible deploys.
IMAGE_TAG=latest

# ─── SMTP (configured via the Admin UI after first login, or set here to seed) ─
# These values are stored in the database after you save them in Admin > SMTP.
# You do NOT need to set these here; they are provided as a reference.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=no-reply@example.com
